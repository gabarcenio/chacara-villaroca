# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth & email ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
OWNER_EMAIL=
RESEND_API_KEY=

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://villaroca.com.br

# ── Autentique — e-signature (optional, Brazilian LGPD-compliant) ─────────────
# Self-serve key at: https://painel.autentique.com.br/perfil/api
# Falls back to emailing the contract as an HTML attachment if not set.
AUTENTIQUE_API_TOKEN=

# ── Mercado Pago — Dynamic Pix QR codes + webhooks (optional) ────────────────
# Self-serve key at: https://www.mercadopago.com.br/developers/panel
# Register webhook URL in MP dashboard → Webhooks:
#   https://villaroca.com.br/api/webhooks/mercadopago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=   # optional: set in MP dashboard → Webhooks → Segredo

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
